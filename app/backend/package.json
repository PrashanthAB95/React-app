{
  "name": "taskmanager-api",
  "version": "1.0.0",
  "description": "TaskManager REST API — Node.js + Express + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "test":    "jest --coverage",
    "test:ci": "jest --ci --coverage --coverageReporters=lcov --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^4.18.2",
    "pg":      "^8.11.0"
  },
  "devDependencies": {
    "jest":          "^29.5.0",
    "jest-junit":    "^16.0.0",
    "nodemon":       "^3.0.1",
    "supertest":     "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    }
  }
}
